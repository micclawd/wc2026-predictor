# Data — we don't ship the 26worldcup.github.io data repo (it's ~100MB).
# Run `bash setup.sh` to clone it after pulling this repo.
data/

# Cache — ESPN lineup caches are ephemeral (1-hour TTL)
cache/

# Download outputs — these are generated by the scripts, not source code.
# We ship a sample in download/ but ignore regenerated files.
download/*.json
!download/wc2026_betting_markets.json
!download/wc2026_predictions.json

# Logs
*.log
logs/

# Secrets
.env
.env.local
*.key
*.pem
secrets/

# Stake session — contains auth tokens, NEVER commit
stake_session.json
scripts/stake_session.json

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Bet log — generated at runtime, contains stake/odds/edge history
bets_log.jsonl
